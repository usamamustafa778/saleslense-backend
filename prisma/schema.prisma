generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// Mongo doesn't support native auto-increment ints, but the existing backend
// logic expects numeric `id` fields. We generate those ids via a sequence collection.
model Sequence {
  mongoId String @id @default(auto()) @map("_id") @db.ObjectId
  key     String @unique
  value   Int    @default(0)

  @@map("sequences")
}

model User {
  mongoId   String           @id @default(auto()) @map("_id") @db.ObjectId
  id        Int              @unique
  email     String           @unique
  password  String
  role      String           @default("user")
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  memberships UserTenantRole[]

  @@map("users")
}

model Tenant {
  mongoId      String           @id @default(auto()) @map("_id") @db.ObjectId
  id           Int              @unique
  name         String
  baseCurrency String           @default("USD")
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  memberships   UserTenantRole[]
  orders        Order[]
  products      Product[]
  costRecords   CostRecord[]
  adSpendRecords AdSpendRecord[]
  rawOrders     RawOrder[]
  rawProducts   RawProduct[]

  @@map("tenants")
}

model UserTenantRole {
  mongoId   String   @id @default(auto()) @map("_id") @db.ObjectId
  id        Int      @unique
  userId    Int
  tenantId  Int
  role      String   @default("user")
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])

  @@map("memberships")
}

model Product {
  mongoId      String   @id @default(auto()) @map("_id") @db.ObjectId
  id           Int      @unique
  tenantId     Int
  sku          String
  name         String
  baseCurrency String   @default("USD")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items  OrderItem[]
  costs  CostRecord[]

  @@unique([tenantId, sku], name: "tenantId_sku")
  @@index([tenantId])
}

model Order {
  mongoId     String   @id @default(auto()) @map("_id") @db.ObjectId
  id          Int      @unique
  tenantId    Int
  externalId  String
  channel     String
  currency    String   @default("USD")
  totalAmount Float    @default(0)
  orderDate   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant  Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items   OrderItem[]
  fees    Fee[]
  refunds Refund[]

  @@unique([tenantId, externalId], name: "tenantId_externalId")
  @@index([tenantId, orderDate])
}

model OrderItem {
  mongoId   String   @id @default(auto()) @map("_id") @db.ObjectId
  id        Int      @unique
  orderId   Int
  productId Int
  quantity  Int      @default(1)
  unitPrice Float    @default(0)
  createdAt DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

model Fee {
  mongoId   String   @id @default(auto()) @map("_id") @db.ObjectId
  id        Int      @unique
  orderId   Int
  category  String   @default("GENERAL")
  amount    Float    @default(0)
  currency  String   @default("USD")
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Refund {
  mongoId   String   @id @default(auto()) @map("_id") @db.ObjectId
  id        Int      @unique
  orderId   Int
  category  String   @default("GENERAL")
  amount    Float    @default(0)
  currency  String   @default("USD")
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model CostRecord {
  mongoId         String   @id @default(auto()) @map("_id") @db.ObjectId
  id              Int      @unique
  tenantId        Int
  productId       Int?
  cogsPerUnit     Float?
  shippingPerUnit Float?
  currency        String   @default("USD")
  effectiveFrom   DateTime @default(now())
  createdAt       DateTime @default(now())

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([tenantId, effectiveFrom])
  @@index([productId])
}

model AdSpendRecord {
  mongoId   String   @id @default(auto()) @map("_id") @db.ObjectId
  id        Int      @unique
  tenantId  Int
  channel   String   @default("GENERIC")
  amount    Float    @default(0)
  currency  String   @default("USD")
  spendDate DateTime @default(now())
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, spendDate])
}

model RawOrder {
  mongoId   String   @id @default(auto()) @map("_id") @db.ObjectId
  id        Int      @unique
  tenantId  Int
  source    String
  rawCsvRow String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model RawProduct {
  mongoId   String   @id @default(auto()) @map("_id") @db.ObjectId
  id        Int      @unique
  tenantId  Int
  source    String
  rawCsvRow String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

