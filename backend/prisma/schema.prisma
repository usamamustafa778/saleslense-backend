generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int               @id @default(autoincrement())
  email     String            @unique
  password  String
  role      String            @default("user")
  tenants   UserTenantRole[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model Tenant {
  id        Int               @id @default(autoincrement())
  name      String
  users     UserTenantRole[]
  baseCurrency String         @default("USD")
  rawOrders RawOrder[]
  rawProducts RawProduct[]
  products  Product[]
  orders    Order[]
  costRecords     CostRecord[]
  adSpendRecords  AdSpendRecord[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model UserTenantRole {
  id       Int    @id @default(autoincrement())
  user     User   @relation(fields: [userId], references: [id])
  userId   Int
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId Int
  role     String

  @@unique([userId, tenantId])
}

model RawOrder {
  id        Int      @id @default(autoincrement())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  tenantId  Int
  source    String
  rawCsvRow String
  createdAt DateTime @default(now())
}

model RawProduct {
  id        Int      @id @default(autoincrement())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  tenantId  Int
  source    String
  rawCsvRow String
  createdAt DateTime @default(now())
}

model Product {
  id           Int           @id @default(autoincrement())
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  tenantId     Int
  sku          String
  name         String
  baseCurrency String        @default("USD")
  orders       OrderItem[]
  costRecords  CostRecord[]

  @@unique([tenantId, sku])
}

model Order {
  id           Int           @id @default(autoincrement())
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  tenantId     Int
  externalId   String
  channel      String
  orderDate    DateTime
  currency     String
  totalAmount  Decimal       @db.Decimal(12, 2)
  fees         Fee[]
  refunds      Refund[]
  items        OrderItem[]

  @@unique([tenantId, externalId])
}

model OrderItem {
  id         Int      @id @default(autoincrement())
  order      Order    @relation(fields: [orderId], references: [id])
  orderId    Int
  product    Product? @relation(fields: [productId], references: [id])
  productId  Int?
  quantity   Int
  unitPrice  Decimal  @db.Decimal(12, 2)
}

model Fee {
  id          Int      @id @default(autoincrement())
  order       Order    @relation(fields: [orderId], references: [id])
  orderId     Int
  category    String
  amount      Decimal  @db.Decimal(12, 2)
  currency    String
}

model Refund {
  id          Int      @id @default(autoincrement())
  order       Order    @relation(fields: [orderId], references: [id])
  orderId     Int
  category    String
  amount      Decimal  @db.Decimal(12, 2)
  currency    String
}

model CostRecord {
  id              Int      @id @default(autoincrement())
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  tenantId        Int
  product         Product? @relation(fields: [productId], references: [id])
  productId       Int?
  cogsPerUnit     Decimal? @db.Decimal(12, 4)
  shippingPerUnit Decimal? @db.Decimal(12, 4)
  currency        String   @default("USD")
  effectiveFrom   DateTime @default(now())
}

model AdSpendRecord {
  id          Int      @id @default(autoincrement())
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  tenantId    Int
  channel     String
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("USD")
  spendDate   DateTime
  createdAt   DateTime @default(now())
}


